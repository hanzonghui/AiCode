  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/left-brain/scripts/pretool-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "UserPromptSubmit",
        "hooks": [
          {
            "type": "command",
            "command": "node H:/AI-han/AiCode/scripts/orchestrator/hooks/dispatch-decision.js",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ],
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/left-brain/scripts/before-hook.sh",
            "timeout": 10,
            "once": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/left-brain/scripts/posttool-hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/left-brain/scripts/auto-perceive.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/skills/left-brain/scripts/auto-save.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/skills/left-brain/scripts/status-line.sh",
    "refreshInterval": 60
  }
}
