# Claude Code ignore file
# 告诉 CC 不要读取这些目录/文件（节省 token）
# 格式类似 .gitignore

# 自动化脚本（按需）
.automation/

# 第三方工具/AI 配置（大且非核心）
.qoder/
.skill/

# 大文件/临时文件
logs/
*.log
*.tmp
*.zip
*.tar.gz

# 编辑器临时文件
*.swp
*.swo
.DS_Store
Thumbs.db

# Git 内部
.git/
.gitignore
.worktrees/

# 内部归档（手动读）
archives/

# 快照存档（量大，按需手动读）
.claude/snapshots/
.claude/skills/left-brain/memory/sessions/
.claude/skills/left-brain/memory/logs/

# 会话级快照模式覆盖（每个会话独立，不入 git）
.claude/session-snap-mode.json

# 依赖/构建输出
node_modules/
dist/
build/
target/

# 进化系统原始数据（量大，按需读）
data/github/trending.json
data/github/candidates.json

# 外部语料库（按需手动 clone + 按文件读，量大 8MB+）
data/corpus/
